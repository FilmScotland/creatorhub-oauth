  "logo_uri": "https://filmscotland.github.io/creatorhub-oauth/logo.png",

  "policy_uri": "https://filmscotland.github.io/creatorhub-oauth/privacy.html",

  "tos_uri": "https://filmscotland.github.io/creatorhub-oauth/terms.html"
